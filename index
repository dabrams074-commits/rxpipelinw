function addRoleToTracker(r, btn){ 
if(addedRoleSet.has(r.id)) return; 
addedRoleSet.add(r.id); saveAddedRoles(); 
if(!jobs.find(j=>j.company==='Pfizer'&&j.role===r.title)){ 
jobs.push({ 
id:uid(), company:'Pfizer', role:r.title, 
url:r.url, 
area:'Diversified', jobtype:'Full-Time', 
level: inferLevel(r.title), func: inferFunc(r.title, r.dept||''), 
stage:'Sourced', priority:'med', recruiter:'', 
notes:`Dept: ${r.dept||'—'}\nLocation: ${r.location||'—'}\nSource: Pfizer Workday (live fetch)`.trim(), 
date:todayStr(), interviews:[], 
activity:[{text:'Added from Pfizer Live Jobs', time:new Date().toISOString()}] 
}); 
saveJobs(); 
