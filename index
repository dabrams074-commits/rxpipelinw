// ── WORKDAY FETCHER ── 
async function fetchWorkday(c){ 
const BASE = `https://${c.subdomain}.wd${c.wdNum}.myworkdayjobs.com/wday/cxs/${c.subdomain}/${c.tenant}/jobs`; 
const LIMIT = 20; 
const key = c.name.replace(/\s/g,'-'); 
let allJobs=[], offset=0, total=null; 

const first = await wdPost(BASE, 0, LIMIT); 
if(!first?.jobPostings) throw new Error('No jobPostings'); 
total = first.total || first.jobPostings.length; 
allJobs = allJobs.concat(first.jobPostings); 
setPBar(key, allJobs.length, total); 

const pages = Math.ceil(total/LIMIT); 
for(let p=1; p<pages; p++){ 
try{ 
const page = await wdPost(BASE, p*LIMIT, LIMIT); 
if(page?.jobPostings) allJobs=allJobs.concat(page.jobPostings); 
setPBar(key, allJobs.length, total); 
} catch(e){ break; } 
} 
return allJobs.map(j=>normalizeJob(j, c.name, `https://${c.subdomain}.wd${c.wdNum}.myworkdayjobs.com/${c.tenant}`)); 
} 

async function wdPost(url, offset, limit){ 
const res = await fetch(url, { 
method:'POST', 
headers:{'Content-Type':'application/json','Accept':'application/json'}, 
body: JSON.stringify({ limit, offset, searchText:'', locations:[], categories:[] }) 
}); 
if(!res.ok) throw new Error(`HTTP ${res.status}`); 
return res.json(); 
} 

