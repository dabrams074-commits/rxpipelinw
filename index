async function fetchPfizerJobs(){ 
const btn = document.getElementById('btn-fetch'); 
const statusEl = document.getElementById('fetch-status'); 
const container = document.getElementById('roles-container'); 

// UI: loading state 
btn.disabled = true; 
btn.classList.add('spinning'); 
statusEl.className = 'fetch-status loading'; 
statusEl.textContent = 'Connecting to Pfizer Workday…'; 
container.innerHTML = skeletons(6); 

// Workday undocumented JSON endpoint — called from browser avoids CORS 
const BASE = 'https://pfizer.wd1.myworkdayjobs.com/wday/cxs/pfizer/PfizerCareers/jobs'; 
const LIMIT = 20; 
let offset = 0; 
let total = null; 
let allJobs = []; 

try { 
// First page — discover total 
const first = await wdFetch(BASE, offset, LIMIT); 
if(!first || !first.jobPostings) throw new Error('Unexpected response format'); 
total = first.total || first.jobPostings.length; 
allJobs = allJobs.concat(first.jobPostings); 
statusEl.textContent = `Fetching ${total} jobs…`; 

// Fetch remaining pages in batches of 5 
const pages = Math.ceil(total / LIMIT); 
const remaining = []; 
for(let p = 1; p < pages; p++) remaining.push(wdFetch(BASE, p * LIMIT, LIMIT)); 

const batchSize = 5; 
for(let i = 0; i < remaining.length; i += batchSize){ 
const batch = await Promise.all(remaining.slice(i, i + batchSize)); 
batch.forEach(r => { if(r && r.jobPostings) allJobs = allJobs.concat(r.jobPostings); }); 
const pct = Math.round(((i + batchSize) / remaining.length) * 100); 
statusEl.textContent = `Fetching… ${Math.min(pct,100)}% (${allJobs.length}/${total} jobs)`; 
} 

pfizer_jobs = allJobs.map(normalizeJob); 
buildFilters(); 
renderRoles(); 

const count = pfizer_jobs.length; 
statusEl.className = 'fetch-status success'; 
statusEl.textContent = `✓ ${count} jobs loaded · ${new Date().toLocaleTimeString()}`; 
document.getElementById('sb-roles').textContent = count; 
document.getElementById('live-roles-count').textContent = count; 
document.getElementById('roles-footer').style.display = 'flex'; 
document.getElementById('footer-text').textContent = 
`${count} live jobs from pfizer.wd1.myworkdayjobs.com · Fetched ${new Date().toLocaleDateString()} · Click any role to view on Pfizer's site`; 

} catch(err) { 
console.error('Pfizer fetch error:', err); 
statusEl.className = 'fetch-status error'; 
statusEl.textContent = `Error: ${err.message}`; 

// CORS fallback — show message and link to careers page 
container.innerHTML = ` 
<div class="fetch-empty"> 
<div class="fetch-empty-icon" style="color:var(--danger)"> 
<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg> 
</div> 
<div class="fetch-empty-title">CORS blocked by browser</div> 
<div class="fetch-empty-sub"> 
Pfizer's Workday site blocks cross-origin requests from the browser security sandbox.<br><br> 
<strong style="color:var(--accent)">To view all Pfizer jobs directly:</strong> 
</div> 
<a href="https://pfizer.wd1.myworkdayjobs.com/PfizerCareers" target="_blank" rel="noopener" 
style="display:inline-flex;align-items:center;gap:8px;background:var(--accent);color:#0d0f14;padding:10px 24px;border-radius:var(--radius);font-family:'Instrument Sans',sans-serif;font-weight:600;font-size:0.85rem;text-decoration:none;margin-top:8px"> 
<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg> 
Open Pfizer Careers on Workday 
</a> 
<div class="fetch-empty-sub" style="margin-top:16px"> 
The Workday JSON API works when accessed directly from your browser but is blocked in sandboxed file: environments.<br> 
When hosted on a real domain (e.g. via Bubble or Vercel), this fetch will work automatically. 
</div> 
</div>`; 
} 

btn.disabled = false; 
btn.classList.remove('spinning'); 
} 

async function wdFetch(url, offset, limit){ 
const res = await fetch(url, { 
method: 'POST', 
headers: { 
'Content-Type': 'application/json', 
'Accept': 'application/json', 
}, 
body: JSON.stringify({ 
limit, 
offset, 
searchText: '', 
locations: [], 
categories: [] 
}) 
}); 
if(!res.ok) throw new Error(`HTTP ${res.status}`); 
return res.json(); 
} 

function normalizeJob(j){ 
// Workday job posting shape 
const title = j.title || j.jobPostingTitle || ''; 
const loc = (j.locationsText || j.primaryLocation || j.bulletFields?.[0] || '').replace(/^\|+/, '').trim(); 
const dept = (j.jobCategory || j.categories?.[0]?.value || '').trim(); 
const posted = j.postedOn ? new Date(j.postedOn).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) : ''; 
const id = j.bulletFields?.[1] || j.externalPath || String(Math.random()); 
const path = j.externalPath || ''; 
const url = path ? `https://pfizer.wd1.myworkdayjobs.com${path}` : 'https://pfizer.wd1.myworkdayjobs.com/PfizerCareers'; 
return { id, title, location:loc, dept, posted, url, raw:j }; 
} 

function buildFilters(){ 
const depts = [...new Set(pfizer_jobs.map(j=>j.dept).filter(Boolean))].sort(); 
const locs = [...new Set(pfizer_jobs.map(j=>j.location).filter(Boolean))].sort(); 

const dEl = document.getElementById('r-dept'); 
dEl.innerHTML = '<option value="">All Departments</option>' + 
depts.map(d=>`<option value="${esc(d)}">${esc(d)}</option>`).join(''); 

const lEl = document.getElementById('r-loc'); 
lEl.innerHTML = '<option value="">All Locations</option>' + 
locs.map(l=>`<option value="${esc(l)}">${esc(l)}</option>`).join(''); 

document.getElementById('roles-filters').style.display = 'flex'; 
} 

function getFilteredRoles(){ 
const q = (document.getElementById('r-search')?.value||'').toLowerCase(); 
const dept = document.getElementById('r-dept')?.value||''; 
const loc = document.getElementById('r-loc')?.value||''; 
return pfizer_jobs.filter(r=>{ 
const mQ = !q || r.title.toLowerCase().includes(q) || r.dept.toLowerCase().includes(q) || r.location.toLowerCase().includes(q); 
const mD = !dept || r.dept===dept; 
const mL = !loc || r.location===loc; 
return mQ && mD && mL; 
}); 
} 

