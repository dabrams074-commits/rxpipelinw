<!DOCTYPE html> 

<html lang="en"> 
<head> 
<meta charset="UTF-8"> 
<meta name="viewport" content="width=device-width, initial-scale=1.0"> 
<title>Rx Pipeline</title> 
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@300;400;500&family=Instrument+Sans:wght@400;500;600&display=swap" rel="stylesheet"> 
<style> 
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; } 

:root { 
–bg: #0d0f14; 
–surface: #13161e; 
–card: #181c26; 
–border: #232840; 
–accent: #4fffb0; 
–accent2: #7c6fff; 
–warn: #ff8c42; 
–danger: #ff4f6d; 
–text: #e8eaf2; 
–muted: #6b7099; 
–soft: #a0a8c8; 
–radius: 8px; 
} 

body { 
font-family: ‘Instrument Sans’, sans-serif; 
background: var(–bg); 
color: var(–text); 
min-height: 100vh; 
overflow-x: hidden; 
} 
body::before { 
content: ‘’; 
position: fixed; top: -200px; left: -200px; 
width: 600px; height: 600px; 
background: radial-gradient(circle, rgba(79,255,176,0.04) 0%, transparent 70%); 
pointer-events: none; z-index: 0; 
} 
body::after { 
content: ‘’; 
position: fixed; bottom: -200px; right: -100px; 
width: 500px; height: 500px; 
background: radial-gradient(circle, rgba(124,111,255,0.05) 0%, transparent 70%); 
pointer-events: none; z-index: 0; 
} 

/* ── HEADER ── */ 
header { 
position: sticky; top: 0; z-index: 100; 
background: rgba(13,15,20,0.92); 
backdrop-filter: blur(16px); 
border-bottom: 1px solid var(–border); 
padding: 0 32px; 
display: flex; align-items: center; gap: 0; 
height: 64px; 
} 
.logo { 
font-family: ‘DM Serif Display’, serif; 
font-size: 1.3rem; 
color: var(–accent); 
display: flex; align-items: center; gap: 10px; 
margin-right: 32px; 
flex-shrink: 0; 
} 
.logo-dot { 
width: 8px; height: 8px; 
background: var(–accent); border-radius: 50%; 
box-shadow: 0 0 10px var(–accent); 
animation: pulse 2s ease-in-out infinite; 
} 
@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.5;transform:scale(0.8)} } 

/* ── NAV TABS ── */ 
.nav-tabs { 
display: flex; align-items: center; gap: 2px; 
flex: 1; 
} 
.nav-tab { 
display: flex; align-items: center; gap: 7px; 
padding: 8px 18px; 
border-radius: var(–radius); 
font-family: ‘DM Mono’, monospace; 
font-size: 0.72rem; 
font-weight: 500; 
text-transform: uppercase; 
letter-spacing: 0.5px; 
cursor: pointer; 
border: none; 
background: transparent; 
color: var(–muted); 
transition: all 0.18s; 
position: relative; 
} 
.nav-tab:hover { color: var(–soft); background: rgba(255,255,255,0.04); } 
.nav-tab.active { color: var(–accent); background: rgba(79,255,176,0.08); } 
.nav-tab .tab-badge { 
font-size: 0.6rem; 
background: rgba(79,255,176,0.15); 
color: var(–accent); 
padding: 1px 6px; 
border-radius: 10px; 
border: 1px solid rgba(79,255,176,0.2); 
} 

/* HEADER RIGHT */ 
.header-right { 
display: flex; align-items: center; gap: 16px; 
margin-left: auto; 
} 
.stat-pill { 
font-family: ‘DM Mono’, monospace; 
font-size: 0.68rem; 
font-weight: 500; 
padding: 4px 12px; 
border-radius: 20px; 
letter-spacing: 0.5px; 
text-transform: uppercase; 
} 
.stat-pill.s-applied { background: rgba(79,255,176,0.1); color: var(–accent); border: 1px solid rgba(79,255,176,0.2); } 
.stat-pill.s-int { background: rgba(124,111,255,0.1); color: var(–accent2); border: 1px solid rgba(124,111,255,0.2); } 
.stat-pill.s-offers { background: rgba(255,140,66,0.1); color: var(–warn); border: 1px solid rgba(255,140,66,0.2); } 

.btn-primary { 
display: flex; align-items: center; gap: 6px; 
background: var(–accent); color: #0d0f14; 
border: none; padding: 8px 18px; 
border-radius: var(–radius); 
font-family: ‘Instrument Sans’, sans-serif; 
font-size: 0.82rem; font-weight: 600; 
cursor: pointer; transition: all 0.2s; 
} 
.btn-primary:hover { background: #2fffa0; transform: translateY(-1px); box-shadow: 0 4px 16px rgba(79,255,176,0.25); } 

/* ── VIEWS ── */ 
.view { display: none; position: relative; z-index: 1; } 
.view.active { display: block; } 

/* ── MAIN WRAPPER ── */ 
.page { max-width: 1400px; margin: 0 auto; padding: 28px 24px; } 

/* ── TOOLBAR ── */ 
.toolbar { 
display: flex; align-items: center; gap: 10px; 
margin-bottom: 24px; flex-wrap: wrap; 
} 
.search-wrap { flex: 1; min-width: 200px; position: relative; } 
.search-wrap svg { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(–muted); pointer-events: none; } 
.search-input { 
width: 100%; 
background: var(–surface); border: 1px solid var(–border); 
color: var(–text); padding: 9px 12px 9px 38px; 
border-radius: var(–radius); 
font-family: ‘Instrument Sans’, sans-serif; font-size: 0.875rem; 
outline: none; transition: border-color 0.2s; 
} 
.search-input:focus { border-color: var(–accent); } 
.search-input::placeholder { color: var(–muted); } 

/* ── DROPDOWN FILTERS ── */ 
.dropdown-wrap { position: relative; } 
.dropdown-trigger { 
display: flex; align-items: center; gap: 7px; 
background: var(–surface); border: 1px solid var(–border); 
color: var(–soft); padding: 9px 13px; 
border-radius: var(–radius); 
font-family: ‘DM Mono’, monospace; font-size: 0.72rem; 
cursor: pointer; transition: all 0.18s; 
text-transform: uppercase; letter-spacing: 0.5px; 
white-space: nowrap; user-select: none; 
} 
.dropdown-trigger:hover { border-color: var(–accent); color: var(–accent); background: rgba(79,255,176,0.06); } 
.dropdown-trigger.active { border-color: var(–accent); color: var(–accent); background: rgba(79,255,176,0.09); } 
.dropdown-trigger svg:last-child { transition: transform 0.18s; } 
.dropdown-trigger.open svg:last-child { transform: rotate(180deg); } 
.active-val { 
font-size: 0.62rem; 
background: rgba(79,255,176,0.15); color: var(–accent); 
padding: 1px 6px; border-radius: 4px; 
max-width: 86px; overflow: hidden; text-overflow: ellipsis; 
} 
.dropdown-menu { 
position: absolute; top: calc(100% + 6px); left: 0; z-index: 200; 
background: var(–card); border: 1px solid var(–border); 
border-radius: var(–radius); padding: 6px; min-width: 190px; 
box-shadow: 0 8px 32px rgba(0,0,0,0.45); 
display: none; flex-direction: column; gap: 2px; 
} 
.dropdown-menu.open { display: flex; } 
.dropdown-item { 
display: flex; align-items: center; justify-content: space-between; 
padding: 7px 10px; border-radius: 5px; 
font-family: ‘DM Mono’, monospace; font-size: 0.7rem; 
color: var(–soft); cursor: pointer; transition: all 0.13s; 
text-transform: uppercase; letter-spacing: 0.3px; 
border: none; background: transparent; width: 100%; text-align: left; 
} 
.dropdown-item:hover { background: rgba(255,255,255,0.05); color: var(–text); } 
.dropdown-item.selected { background: rgba(79,255,176,0.09); color: var(–accent); } 
.dropdown-item .check { 
width: 14px; height: 14px; border-radius: 3px; 
border: 1px solid var(–border); flex-shrink: 0; 
display: flex; align-items: center; justify-content: center; 
} 
.dropdown-item.selected .check { background: var(–accent); border-color: var(–accent); } 
.dropdown-divider { height: 1px; background: var(–border); margin: 4px 0; } 

.filter-clear-btn { 
background: transparent; border: 1px solid var(–border); 
color: var(–muted); padding: 9px 14px; 
border-radius: var(–radius); 
font-family: ‘DM Mono’, monospace; font-size: 0.7rem; 
cursor: pointer; transition: all 0.18s; 
text-transform: uppercase; letter-spacing: 0.5px; 
} 
.filter-clear-btn:hover { border-color: var(–danger); color: var(–danger); } 

.result-count { 
font-family: ‘DM Mono’, monospace; font-size: 0.7rem; 
color: var(–muted); white-space: nowrap; padding: 0 4px; 
} 

/* ── INTEGRATED SEARCH BAR ── */ 
.search-bar { 
display: flex; align-items: center; 
background: var(–surface); 
border: 1px solid var(–border); 
border-radius: 10px; 
margin-bottom: 24px; 
transition: border-color 0.2s; 
overflow: hidden; 
} 
.search-bar:focus-within { border-color: rgba(79,255,176,0.35); } 

.sb-input-wrap { 
display: flex; align-items: center; gap: 10px; 
padding: 0 16px; flex: 1; min-width: 0; 
border-right: 1px solid var(–border); 
} 
.sb-input-wrap svg { color: var(–muted); flex-shrink: 0; } 
.sb-input { 
background: transparent; border: none; outline: none; 
color: var(–text); font-family: ‘Instrument Sans’, sans-serif; 
font-size: 0.875rem; padding: 13px 0; width: 100%; 
} 
.sb-input::placeholder { color: var(–muted); } 

.sb-select { 
background: transparent; border: none; outline: none; 
color: var(–muted); font-family: ‘DM Mono’, monospace; 
font-size: 0.68rem; padding: 13px 16px; 
cursor: pointer; transition: color 0.15s; 
border-right: 1px solid var(–border); 
appearance: none; text-transform: uppercase; letter-spacing: 0.5px; 
white-space: nowrap; flex-shrink: 0; 
} 
.sb-select:hover { color: var(–soft); background: rgba(255,255,255,0.02); } 
.sb-select:focus { color: var(–accent); outline: none; } 
.sb-select.active { color: var(–accent); } 
.sb-select option { background: var(–card); color: var(–text); font-family: ‘Instrument Sans’, sans-serif; } 

.sb-divider { width: 1px; background: var(–border); align-self: stretch; flex-shrink: 0; } 

.sb-clear { 
background: transparent; border: none; 
color: var(–muted); padding: 13px 16px; 
cursor: pointer; font-family: ‘DM Mono’, monospace; 
font-size: 0.65rem; transition: color 0.15s; 
text-transform: uppercase; letter-spacing: 0.3px; 
white-space: nowrap; display: none; flex-shrink: 0; 
} 
.sb-clear:hover { color: var(–danger); } 
.sb-clear.show { display: block; } 

/* ── KANBAN ── */ 
.kanban { 
display: grid; grid-template-columns: repeat(4,1fr); 
gap: 14px; align-items: start; 
} 
.column { 
background: var(–surface); border: 1px solid var(–border); 
border-radius: 10px; overflow: hidden; 
} 
.col-header { 
padding: 13px 15px; 
display: flex; align-items: center; justify-content: space-between; 
border-bottom: 1px solid var(–border); 
} 
.col-title { 
font-family: ‘DM Mono’, monospace; font-size: 0.68rem; 
font-weight: 500; text-transform: uppercase; letter-spacing: 1px; 
display: flex; align-items: center; gap: 8px; 
} 
.col-dot { width: 7px; height: 7px; border-radius: 50%; } 
.col-count { 
font-family: ‘DM Mono’, monospace; font-size: 0.68rem; 
color: var(–muted); background: rgba(255,255,255,0.05); 
padding: 2px 8px; border-radius: 10px; 
} 
.col-body { padding: 10px; display: flex; flex-direction: column; gap: 8px; min-height: 80px; } 

/* ── JOB CARD ── */ 
.job-card { 
background: var(–card); border: 1px solid var(–border); 
border-radius: var(–radius); padding: 13px; 
transition: all 0.18s; position: relative; overflow: hidden; 
} 
.job-card::before { 
content: ‘’; position: absolute; 
left: 0; top: 0; bottom: 0; width: 3px; 
border-radius: 3px 0 0 3px; 
} 
.job-card:hover { border-color: rgba(79,255,176,0.28); transform: translateY(-1px); box-shadow: 0 4px 16px rgba(0,0,0,0.3); } 
.pri-high::before { background: var(–danger); } 
.pri-med::before { background: var(–warn); opacity: 0.7; } 
.pri-low::before { background: var(–muted); opacity: 0.5; } 

.card-company { font-family: ‘DM Serif Display’, serif; font-size: 0.98rem; color: var(–text); margin-bottom: 2px; line-height: 1.2; } 
.card-role { font-size: 0.76rem; color: var(–soft); margin-bottom: 9px; line-height: 1.4; } 
.card-tags { display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 9px; } 
.tag { 
font-family: ‘DM Mono’, monospace; font-size: 0.6rem; 
padding: 2px 7px; border-radius: 3px; 
text-transform: uppercase; letter-spacing: 0.3px; 
} 
.tag.area { background: rgba(124,111,255,0.12); color: var(–accent2); border: 1px solid rgba(124,111,255,0.15); } 
.tag.muted { background: rgba(255,255,255,0.05); color: var(–muted); border: 1px solid var(–border); } 
.tag.green { background: rgba(79,255,176,0.08); color: var(–accent); border: 1px solid rgba(79,255,176,0.15); } 
.tag.orange { background: rgba(255,140,66,0.08); color: var(–warn); border: 1px solid rgba(255,140,66,0.15); } 

.card-notes { 
font-size: 0.73rem; color: var(–muted); margin-bottom: 9px; 
line-height: 1.5; 
display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; 
} 
.card-footer { 
display: flex; align-items: center; justify-content: space-between; 
padding-top: 9px; border-top: 1px solid var(–border); 
} 
.card-date { font-family: ‘DM Mono’, monospace; font-size: 0.63rem; color: var(–muted); } 
.card-actions { display: flex; gap: 5px; } 
.card-btn { 
display: flex; align-items: center; gap: 4px; 
font-family: ‘DM Mono’, monospace; font-size: 0.63rem; 
padding: 4px 8px; border-radius: 4px; 
border: 1px solid var(–border); cursor: pointer; 
transition: all 0.13s; text-decoration: none; letter-spacing: 0.3px; 
} 
.card-btn.site { background: rgba(79,255,176,0.07); color: var(–accent); border-color: rgba(79,255,176,0.2); } 
.card-btn.site:hover { background: rgba(79,255,176,0.16); } 
.card-btn.edit { background: transparent; color: var(–muted); } 
.card-btn.edit:hover { color: var(–soft); border-color: var(–soft); } 
.card-btn.del { background: transparent; color: var(–muted); } 
.card-btn.del:hover { background: rgba(255,79,109,0.1); color: var(–danger); border-color: rgba(255,79,109,0.3); } 

.empty-col { 
padding: 20px 12px; text-align: center; 
font-family: ‘DM Mono’, monospace; font-size: 0.66rem; 
color: var(–muted); text-transform: uppercase; letter-spacing: 0.5px; opacity: 0.6; 
} 

/* ── MODAL ── */ 
.modal-overlay { 
position: fixed; inset: 0; z-index: 500; 
background: rgba(0,0,0,0.75); backdrop-filter: blur(4px); 
display: flex; align-items: center; justify-content: center; 
padding: 24px; opacity: 0; pointer-events: none; transition: opacity 0.2s; 
} 
.modal-overlay.open { opacity: 1; pointer-events: all; } 
.modal { 
background: var(–card); border: 1px solid var(–border); 
border-radius: 14px; padding: 28px; 
width: 100%; max-width: 520px; 
transform: translateY(16px); transition: transform 0.2s; 
max-height: 90vh; overflow-y: auto; 
} 
.modal-overlay.open .modal { transform: translateY(0); } 
.modal-title { font-family: ‘DM Serif Display’, serif; font-size: 1.35rem; margin-bottom: 20px; } 
.form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 13px; } 
.form-full { grid-column: 1/-1; } 
.field label { 
display: block; font-family: ‘DM Mono’, monospace; 
font-size: 0.65rem; color: var(–muted); 
text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 5px; 
} 
.field input, .field select, .field textarea { 
width: 100%; background: var(–surface); 
border: 1px solid var(–border); color: var(–text); 
padding: 9px 11px; border-radius: var(–radius); 
font-family: ‘Instrument Sans’, sans-serif; font-size: 0.84rem; 
outline: none; transition: border-color 0.18s; appearance: none; 
} 
.field input:focus, .field select:focus, .field textarea:focus { border-color: var(–accent); } 
.field select { cursor: pointer; } 
.field textarea { resize: vertical; min-height: 68px; } 
.modal-actions { 
display: flex; gap: 10px; justify-content: flex-end; 
margin-top: 20px; padding-top: 18px; border-top: 1px solid var(–border); 
} 
.btn-cancel { 
background: transparent; border: 1px solid var(–border); color: var(–soft); 
padding: 9px 20px; border-radius: var(–radius); 
font-family: ‘Instrument Sans’, sans-serif; font-size: 0.84rem; 
cursor: pointer; transition: all 0.18s; 
} 
.btn-cancel:hover { border-color: var(–soft); color: var(–text); } 
.btn-save { 
background: var(–accent); color: #0d0f14; border: none; 
padding: 9px 24px; border-radius: var(–radius); 
font-family: ‘Instrument Sans’, sans-serif; font-size: 0.84rem; font-weight: 600; 
cursor: pointer; transition: all 0.18s; 
} 
.btn-save:hover { background: #2fffa0; } 

/* ── LIBRARY ── */ 
.lib-header { margin-bottom: 22px; } 
.lib-title { font-family: ‘DM Serif Display’, serif; font-size: 1.7rem; margin-bottom: 5px; } 
.lib-sub { font-family: ‘DM Mono’, monospace; font-size: 0.7rem; color: var(–muted); letter-spacing: 0.3px; } 
.lib-sub strong { color: var(–accent); } 

.lib-toolbar { display: flex; align-items: center; gap: 10px; margin-bottom: 22px; flex-wrap: wrap; } 

.filter-select { 
background: var(–surface); border: 1px solid var(–border); 
color: var(–soft); padding: 9px 13px; 
border-radius: var(–radius); 
font-family: ‘DM Mono’, monospace; font-size: 0.7rem; 
outline: none; cursor: pointer; transition: border-color 0.18s; 
appearance: none; min-width: 155px; letter-spacing: 0.3px; 
text-transform: uppercase; 
} 
.filter-select:focus, .filter-select:hover { border-color: var(–accent); color: var(–text); } 

.view-toggle { 
display: flex; background: var(–surface); 
border: 1px solid var(–border); border-radius: var(–radius); overflow: hidden; 
} 
.view-btn { 
background: transparent; border: none; color: var(–muted); 
padding: 9px 13px; cursor: pointer; transition: all 0.13s; 
display: flex; align-items: center; 
} 
.view-btn.active { background: rgba(79,255,176,0.1); color: var(–accent); } 
.view-btn:hover:not(.active) { color: var(–soft); } 

/* COMPANY GRID */ 
.company-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(270px, 1fr)); gap: 11px; } 
.company-list { display: flex; flex-direction: column; gap: 6px; } 

.co-card { 
background: var(–card); border: 1px solid var(–border); 
border-radius: var(–radius); padding: 16px; 
transition: all 0.18s; position: relative; overflow: hidden; 
} 
.co-card::after { 
content: ‘’; position: absolute; top: 0; left: 0; right: 0; 
height: 2px; background: linear-gradient(90deg, var(–accent), var(–accent2)); 
opacity: 0; transition: opacity 0.18s; 
} 
.co-card:hover { border-color: rgba(79,255,176,0.25); transform: translateY(-1px); box-shadow: 0 4px 18px rgba(0,0,0,0.3); } 
.co-card:hover::after { opacity: 1; } 

.co-card-inner { display: flex; align-items: flex-start; gap: 11px; margin-bottom: 9px; } 
.co-avatar { 
width: 38px; height: 38px; border-radius: 7px; 
border: 1px solid var(–border); 
display: flex; align-items: center; justify-content: center; 
font-family: ‘DM Serif Display’, serif; font-size: 0.95rem; 
color: var(–accent); background: rgba(79,255,176,0.06); flex-shrink: 0; 
} 
.co-name { font-family: ‘DM Serif Display’, serif; font-size: 0.95rem; color: var(–text); line-height: 1.2; margin-bottom: 2px; } 
.co-hq { font-family: ‘DM Mono’, monospace; font-size: 0.6rem; color: var(–muted); text-transform: uppercase; letter-spacing: 0.3px; } 
.co-desc { font-size: 0.73rem; color: var(–muted); line-height: 1.5; margin-bottom: 10px; 
display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; } 
.co-tags { display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 12px; } 
.co-tag { font-family: ‘DM Mono’, monospace; font-size: 0.58rem; padding: 2px 6px; border-radius: 3px; text-transform: uppercase; letter-spacing: 0.3px; } 
.co-tag.t-area { background: rgba(124,111,255,0.12); color: var(–accent2); border: 1px solid rgba(124,111,255,0.15); } 
.co-tag.t-size { background: rgba(255,255,255,0.05); color: var(–muted); border: 1px solid var(–border); } 

.co-actions { display: flex; gap: 7px; align-items: center; } 
.btn-visit { 
display: flex; align-items: center; gap: 5px; 
font-family: ‘DM Mono’, monospace; font-size: 0.63rem; 
padding: 5px 11px; border-radius: 4px; 
border: 1px solid rgba(79,255,176,0.2); 
background: rgba(79,255,176,0.07); color: var(–accent); 
text-decoration: none; cursor: pointer; transition: all 0.13s; 
letter-spacing: 0.3px; text-transform: uppercase; 
} 
.btn-visit:hover { background: rgba(79,255,176,0.16); } 
.btn-add-co { 
display: flex; align-items: center; gap: 5px; 
font-family: ‘DM Mono’, monospace; font-size: 0.63rem; 
padding: 5px 11px; border-radius: 4px; 
border: 1px solid var(–border); background: transparent; color: var(–soft); 
cursor: pointer; transition: all 0.13s; letter-spacing: 0.3px; text-transform: uppercase; 
} 
.btn-add-co:hover:not(.added) { border-color: var(–accent); color: var(–accent); background: rgba(79,255,176,0.05); } 
.btn-add-co.added { border-color: rgba(79,255,176,0.3); color: var(–accent); background: rgba(79,255,176,0.08); cursor: default; } 

/* LIST MODE */ 
.company-list .co-card { padding: 11px 15px; } 
.company-list .co-card-inner { margin-bottom: 0; align-items: center; } 
.company-list .co-desc { display: none; } 
.company-list .co-tags { margin-bottom: 0; } 
.company-list .co-bottom { display: flex; align-items: center; justify-content: space-between; flex: 1; min-width: 0; gap: 12px; } 
.company-list .co-main { flex: 1; min-width: 0; } 

/* TOAST */ 
.toast { 
position: fixed; bottom: 28px; left: 50%; 
transform: translateX(-50%) translateY(80px); 
background: var(–card); border: 1px solid var(–accent); 
border-radius: var(–radius); padding: 11px 22px; 
font-family: ‘DM Mono’, monospace; font-size: 0.73rem; color: var(–accent); 
z-index: 999; transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1); 
white-space: nowrap; box-shadow: 0 8px 28px rgba(0,0,0,0.4); 
} 
.toast.show { transform: translateX(-50%) translateY(0); } 

/* ── NOTES PANEL ── */ 
.panel-overlay { 
position: fixed; inset: 0; z-index: 400; 
background: rgba(0,0,0,0.5); 
