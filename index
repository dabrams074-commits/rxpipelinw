} 

function inferLevel(title){ 
const t = title.toLowerCase(); 
if(t.includes('chief') || t.includes('cso') || t.includes('coo')) return 'C-Suite'; 
if(t.includes('executive vice') || t.includes('evp')) return 'SVP / EVP'; 
if(t.includes('senior vice') || t.includes('svp')) return 'SVP / EVP'; 
if(t.includes('vice president') || t.includes(' vp ') || t.startsWith('vp ')) return 'VP'; 
if(t.includes('senior director')) return 'Senior Director'; 
if(t.includes('director')) return 'Director'; 
if(t.includes('senior manager')) return 'Senior Manager'; 
if(t.includes('manager')) return 'Manager'; 
if(t.includes('associate director')) return 'Associate Director'; 
if(t.includes('associate')) return 'Associate'; 
return 'Other'; 
} 

function inferFunc(title, dept){ 
const t = (title+' '+dept).toLowerCase(); 
if(t.includes('forecast')) return 'Forecasting'; 
if(t.includes('market research')) return 'Market Research'; 
if(t.includes('market access') || t.includes('payer') || t.includes('reimburs')) return 'Market Access'; 
if(t.includes('medical affairs') || t.includes('medical science') || t.includes('msl')) return 'Medical Affairs'; 
if(t.includes('insight') || t.includes('analytics') || t.includes('intelligence')) return 'Commercial Analytics'; 
if(t.includes('marketing')) return 'Marketing'; 
if(t.includes('clinical')) return 'Clinical'; 
if(t.includes('regulatory')) return 'Regulatory'; 
if(t.includes('finance') || t.includes('fp&a') || t.includes('pricing')) return 'Finance'; 
if(t.includes('strategy') || t.includes('business development') || t.includes('bd')) return 'Strategy'; 
if(t.includes('supply') || t.includes('manufactur') || t.includes('operations')) return 'Operations'; 
return 'Other'; 
} 

function exportRolesCSV(){ 
const list = pfizer_filtered.length ? pfizer_filtered : pfizer_jobs; 
if(!list.length){ showToast('No roles loaded — fetch first'); return; } 
const headers = ['Title','Department','Location','Posted','URL']; 
const rows = list.map(r=>[r.title,r.dept,r.location,r.posted,r.url].map(v=>'"'+(String(v||'').replace(/"/g,'""'))+'"')); 
const csv = [headers.join(','),...rows.map(r=>r.join(','))].join('\n'); 
const blob = new Blob([csv],{type:'text/csv'}); 
const a = document.createElement('a'); 
a.href = URL.createObjectURL(blob); 
a.download = `pfizer-jobs-${todayStr()}.csv`; 
a.click(); URL.revokeObjectURL(a.href); 
showToast(`Exported ${list.length} Pfizer roles to CSV`); 
} 

function skeletons(n){ 
return Array(n).fill(0).map(()=>` 
<div class="role-skeleton"> 
<div class="skel-line" style="width:60%;height:16px"></div> 
<div class="skel-line" style="width:30%;height:11px;margin-top:10px"></div> 
<div class="skel-line" style="width:45%;height:11px"></div> 
</div>`).join(''); 
} 

